-----Data Cleaning-----
SELECT 
    player,
    goals,
    assists,
    Ds,
    touches,
    turnovers,
    points_played,
    plus_minus,
    catches,
    drops
FROM append_1;

-----Metric Creation------

SELECT 
    player,
    turnovers,
    catches,
    CAST(turnovers AS FLOAT) / NULLIF(catches, 0) AS turnover_rate
FROM append_1;

SELECT 
    player,
    (goals + assists) AS scoring_contributions,
    points_played,
    CAST((goals + assists) AS FLOAT) / NULLIF(points_played, 0) AS scoring_involvement_rate
FROM append_1;

SELECT
   players,
   points_played,
   plus_minus,
   (goals + assists) AS scoring_contributions,
   CAST((scoring_contributions * 2)+(Ds/points_played)*1.5)+(plus_minus/points_played) AS impact_score

------Analytical Queries---------

SELECT 
    player,
    CAST((goals + assists) AS FLOAT) / NULLIF(points_played, 0) AS scoring_involvement_rate,
    CAST(turnovers AS FLOAT) / NULLIF(catches, 0) AS turnover_rate
FROM append_1;

SELECT
    player,
    touches,
    points_played,
    plus_minus,
    (goals + assists) AS scoring_contributions,
    CAST((scoring_contributions * 2)+(Ds/points_played)*1.5)+(plus_minus/points_played) AS impact_score
From append_1
ORDER BY touches DESC;

SELECT 
    player,
    points_played,
    plus_minus
FROM append_1
ORDER BY points_played ASC;

SELECT 
    player,
    goals,
    assists,
    Ds
FROM append_1
ORDER BY goals DESC;
